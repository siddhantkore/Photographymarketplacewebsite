NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:5000/api/v1
CLIENT_URL=http://localhost:5173

# Backend server
PORT=5000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photomarket
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/photomarket?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Seeded admin (only seeded account)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123

# Storage (MinIO)
STORAGE_PROVIDER=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_REGION=us-east-1
MINIO_ENDPOINT=http://localhost:9000
MINIO_FORCE_PATH_STYLE=true
PREVIEW_BUCKET_NAME=preview-assets
ORIGINAL_BUCKET_NAME=original-assets
PREVIEW_PUBLIC_BASE_URL=http://localhost:9000/preview-assets
ORIGINAL_PUBLIC_BASE_URL=http://localhost:9000/original-assets
STORAGE_SIGNED_URL_EXPIRY=3600

# Payments
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me
PAYMENT_CURRENCY=INR

# Optional ads
GOOGLE_ADSENSE_CLIENT_ID=
