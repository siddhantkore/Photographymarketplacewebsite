// Prisma schema for Photography Marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ProductType {
  PHOTO
  BUNDLE
  TYPOGRAPHY
  POSTER
  BANNER
}

enum Resolution {
  HD
  FULL_HD
  FOUR_K
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
  SQUARE
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AdPosition {
  HOME_SIDEBAR
  EXPLORE
  BLOG
  PRODUCT_GRID
  SIDE_RAIL
  ANCHOR
  VIGNETTE
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  isEmailVerified Boolean @default(false)
  role          UserRole  @default(USER)
  joinDate      DateTime  @default(now())
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  orders        Order[]
  cartItems     CartItem[]
  refreshTokens RefreshToken[]
  wishlistItems WishlistItem[]
  
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

model Product {
  id            String       @id @default(uuid())
  title         String
  description   String       @db.Text
  type          ProductType
  categories    String[]
  tags          String[]
  
  // Preview images (watermarked, low quality) - publicly accessible
  previewImageHD      String
  previewImageFullHD  String
  previewImage4K      String
  
  // For bundles - preview images (watermarked)
  bundlePreviewsHD     String[]
  bundlePreviewsFullHD String[]
  bundlePreviews4K     String[]
  
  // Original files (no watermark, high quality) - secured, only via signed URLs
  originalFileHD      String   // S3 key for HD original
  originalFileFullHD  String   // S3 key for Full HD original
  originalFile4K      String   // S3 key for 4K original
  
  // For bundles - original files
  bundleOriginalsHD     String[] // S3 keys for HD bundle originals
  bundleOriginalsFullHD String[] // S3 keys for Full HD bundle originals
  bundleOriginals4K     String[] // S3 keys for 4K bundle originals
  
  orientation   Orientation
  uploadDate    DateTime     @default(now())
  popularity    Int          @default(0)
  priceHD       Float
  priceFullHD   Float
  price4K       Float
  displayPriceHD     Float?
  displayPriceFullHD Float?
  displayPrice4K     Float?
  featured      Boolean      @default(false)
  status        Status       @default(ACTIVE)
  filesCount    Int          @default(1) // Number of files in bundle (1 for single photo)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  
  @@index([type])
  @@index([status])
  @@index([popularity])
  @@index([featured, status])
}

model Category {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  image        String
  productCount Int      @default(0)
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([slug])
  @@index([status])
}

model CartItem {
  id         String     @id @default(uuid())
  userId     String
  productId  String
  resolution Resolution
  price      Float
  createdAt  DateTime   @default(now())
  
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId, resolution])
  @@index([userId])
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  total         Float
  status        OrderStatus @default(PENDING)
  paymentId     String?
  paymentMethod String?
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  paymentEvents PaymentEvent[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         String     @id @default(uuid())
  orderId    String
  productId  String
  resolution Resolution
  price      Float
  downloadUrl String?
  accessStartTime DateTime?
  accessExpiryTime DateTime?
  createdAt  DateTime   @default(now())
  
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([accessExpiryTime])
}

model PaymentEvent {
  id          String   @id @default(uuid())
  eventId     String?  @unique
  eventType   String
  gateway     String   @default("RAZORPAY")
  orderId     String?
  paymentId   String?
  signature   String?
  status      String   @default("RECEIVED")
  payload     Json
  processedAt DateTime?
  createdAt   DateTime @default(now())

  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([paymentId])
  @@index([eventType])
  @@index([createdAt])
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  excerpt   String   @db.Text
  content   String   @db.Text
  image     String
  author    String
  tags      String[]
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([date])
}

model Advertisement {
  id        String     @id @default(uuid())
  image     String
  url       String
  status    Status     @default(ACTIVE)
  position  AdPosition
  priority  Int        @default(0)  // Higher priority shows first
  gridIndex Int?       // For PRODUCT_GRID, which position (e.g., after 6th product)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([position, status])
  @@index([priority])
}

model GoogleAdSettings {
  id              String   @id @default(uuid())
  adClientId      String   // Google AdSense client ID
  enableVignette  Boolean  @default(false)
  enableSideRail  Boolean  @default(false)
  enableAnchor    Boolean  @default(false)
  vignettePlaces  String[] // Pages where vignette ads show
  sideRailPlaces  String[] // Pages where side rail ads show
  anchorPlaces    String[] // Pages where anchor ads show
  excludedPages   String[] // Pages with no ads (payment, checkout)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  icon        String   // Icon name or image URL
  price       String?  // e.g., "Starting from ₹25,000" or "Custom Quote"
  features    String[] // List of features included
  image       String?  // Optional service image
  status      Status   @default(ACTIVE)
  order       Int      @default(0) // For custom ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status, order])
}

model ContactInquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  subject     String
  message     String   @db.Text
  inquiryType String   // 'service', 'advertisement', 'general'
  serviceId   String?  // If inquiry is for a specific service
  status      String   @default("NEW") // NEW, READ, RESPONDED, CLOSED
  adminTag    String?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status, createdAt])
  @@index([inquiryType])
  @@index([adminTag])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model EmailOtp {
  id         String     @id @default(uuid())
  email      String
  code       String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int        @default(0)
  verifiedAt DateTime?
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model SiteConfig {
  id                  String   @id @default(uuid())
  phoneNumber         String   @default("+91 98765 43210")
  email               String   @default("info@likephotostudio.com")
  address             String?
  signedUrlDuration   Int      @default(3600) // Duration in seconds (default 1 hour)
  watermarkText       String   @default("LIKE PHOTO STUDIO")
  watermarkOpacity    Int      @default(30) // 0-100
  previewQuality      Int      @default(60) // JPEG quality for preview (0-100)
  allowedImageFormats String[] @default(["jpg", "jpeg", "png", "webp"])
  maxFileSize         Int      @default(52428800) // 50MB in bytes
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
